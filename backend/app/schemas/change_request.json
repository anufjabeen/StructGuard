{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "ChangeRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "change_type",
    "risk_level",
    "affected_services",
    "requested_by",
    "requested_at",
    "implementation_window",
    "rollback_plan",
    "approval_status",
    "business_justification"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 140
    },
    "change_type": {
      "type": "string",
      "enum": ["standard", "normal", "emergency"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "affected_services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "requested_by": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "team"],
      "properties": {
        "name": {
          "type": "string"
        },
        "team": {
          "type": "string"
        }
      }
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "implementation_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["starts_at", "ends_at"],
      "properties": {
        "starts_at": {
          "type": "string",
          "format": "date-time"
        },
        "ends_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "rollback_plan": {
      "type": "string",
      "minLength": 20
    },
    "approval_status": {
      "type": "string",
      "enum": ["pending", "approved", "rejected"]
    },
    "business_justification": {
      "type": "string",
      "minLength": 20
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reviewers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "role"],
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["owner", "security", "operations", "product"]
          }
        }
      }
    }
  }
}

